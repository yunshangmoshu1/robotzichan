# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# JWT
JWT_SECRET=your-jwt-secret-change-this
JWT_EXPIRES_IN=7d

# Server
PORT=3000

# DingTalk Open Platform
DINGTALK_APP_KEY=your-app-key
DINGTALK_APP_SECRET=your-app-secret
DINGTALK_AGENT_ID=your-agent-id
DINGTALK_WEBHOOK_URL=your-webhook-url

# DingTalk AI Table / Notable API requires operatorId.
# In this project the verified working value is the DingTalk user's openId.
DINGTALK_OPERATOR_ID=your-user-open-id
